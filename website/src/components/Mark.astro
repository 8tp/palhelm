---
/**
 * The v3 "sphere-wheel" mark: helm ring + 8 ticks, a capture sphere split on the
 * ↗ diagonal with a leaf-green upper-left half and a small offset diamond window.
 * Geometry matches the favicons.
 * The sphere fills are ALWAYS --sphere (the brand's capture green); ring/ticks/split
 * take `color` so contexts like the olive spine can pass their remapped accent.
 */
interface Props {
  size?: number;
  /** stroke/fill for ring, ticks, and the split chord */
  color?: string;
  class?: string;
}
const { size = 26, color = "var(--accent)", class: className } = Astro.props;
---
<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 26 26"
  fill="none"
  aria-hidden="true"
>
  <path d="M6.99 19.01 A8.5 8.5 0 1 1 19.01 6.99 Z" fill="var(--sphere)"></path>
  <path d="M6.99 19.01 L19.01 6.99" stroke={color} stroke-width="2" stroke-linecap="round"></path>
  <rect x="15.1" y="15.1" width="3.0" height="3.0" rx="0.6" transform="rotate(45 16.6 16.6)" fill="var(--sphere)"></rect>
  <circle cx="13" cy="13" r="8.5" stroke={color} stroke-width="2"></circle>
  <g stroke={color} stroke-width="2" stroke-linecap="round">
    <path d="M13 1.5v4"></path><path d="M13 20.5v4"></path>
    <path d="M1.5 13h4"></path><path d="M20.5 13h4"></path>
    <path d="M4.87 4.87l2.83 2.83"></path><path d="M18.3 18.3l2.83 2.83"></path>
    <path d="M21.13 4.87l-2.83 2.83"></path><path d="M7.7 18.3l-2.83 2.83"></path>
  </g>
</svg>
